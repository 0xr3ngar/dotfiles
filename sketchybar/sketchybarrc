#!/bin/bash

PLUGIN_DIR="$CONFIG_DIR/plugins"

# Colors - Ember
BAR_COLOR=0x00000000
ACTIVE_COLOR=0xffe08060
INACTIVE_COLOR=0xff3e3c38
MUTED_COLOR=0xff908a7e
TEXT_COLOR=0xffd8d0c0
ACCENT_COLOR=0xffc8b468
BUBBLE_COLOR=0xee1c1b19
BUBBLE_BORDER=0xff3e3c38

# Bar
sketchybar --bar height=40 \
                 position=bottom \
                 y_offset=0 \
                 padding_left=8 \
                 padding_right=8 \
                 color=$BAR_COLOR \
                 blur_radius=0 \
                 shadow=off

# Defaults
sketchybar --default padding_left=4 \
                     padding_right=4 \
                     y_offset=4 \
                     background.height=28 \
                     background.corner_radius=8 \
                     icon.font="JetBrainsMono Nerd Font:Bold:14.0" \
                     icon.color=$TEXT_COLOR \
                     label.font="JetBrainsMono Nerd Font:Medium:12.0" \
                     label.color=$TEXT_COLOR

# LEFT: Spaces Bubble
for i in {1..9}; do
    sketchybar --add space space.$i left \
               --set space.$i associated_space=$i \
                               icon="$i" \
                               width=28 \
                               icon.font="JetBrainsMono Nerd Font:Bold:13.0" \
                               icon.width=28 \
                               icon.align=center \
                               icon.padding_left=0 \
                               icon.padding_right=0 \
                               background.drawing=on \
                               background.color=0x00e08060 \
                               background.height=24 \
                               background.corner_radius=8 \
                               label.drawing=off \
                               script="$PLUGIN_DIR/space.sh" \
                               click_script="yabai -m space --focus $i"
done

sketchybar --add bracket spaces_group '/space\..*/' \
           --set spaces_group background.drawing=on \
                                y_offset=4 \
                                background.color=$BUBBLE_COLOR \
                                background.border_color=$BUBBLE_BORDER \
                                background.border_width=1 \
                                background.height=30 \
                                background.corner_radius=12

# CENTER: Date / Time
sketchybar --add item center_datetime center \
           --set center_datetime update_freq=10 \
                                  width=132 \
                                  icon.drawing=off \
                                  label.color=$TEXT_COLOR \
                                  label.font="JetBrainsMono Nerd Font:Bold:13.0" \
                                  label.width=124 \
                                  label.align=center \
                                  label.padding_left=8 \
                                  label.padding_right=8 \
                                  background.drawing=on \
                                  background.color=$BUBBLE_COLOR \
                                  background.border_color=$BUBBLE_BORDER \
                                  background.border_width=1 \
                                  background.height=30 \
                                  background.corner_radius=15 \
                                  script="$PLUGIN_DIR/datetime.sh"

# RIGHT: Status Bubble
STATUS_BACKGROUND=$BUBBLE_COLOR
STATUS_BORDER=$BUBBLE_BORDER
STATUS_ICON_COLOR=0xffb8b0a4

sketchybar --add item settings right \
           --set settings width=26 \
                         icon="􀣺" \
                         icon.color=$STATUS_ICON_COLOR \
                         icon.font="SF Pro:Semibold:13.0" \
                         icon.padding_left=6 \
                         icon.padding_right=8 \
                         label.drawing=off \
                         background.drawing=off \
                         click_script="open -a 'System Settings'"

sketchybar --add item right_sep.1 right \
           --set right_sep.1 width=4 \
                               icon.drawing=off \
                               label.drawing=off \
                               background.drawing=off

sketchybar --add item battery right \
           --set battery update_freq=120 \
                          width=58 \
                          icon="􀛨" \
                          icon.color=$STATUS_ICON_COLOR \
                          icon.font="SF Pro:Semibold:13.0" \
                          icon.padding_left=8 \
                          icon.padding_right=4 \
                          label.color=$TEXT_COLOR \
                          label.font="JetBrainsMono Nerd Font:Medium:12.0" \
                          label.padding_right=8 \
                          background.drawing=off \
                          click_script="open 'x-apple.systempreferences:com.apple.Battery-Settings.extension'" \
                          script="$PLUGIN_DIR/battery.sh" \
             --subscribe battery system_woke power_source_change

sketchybar --add item right_sep.2 right \
           --set right_sep.2 width=4 \
                               icon.drawing=off \
                               label.drawing=off \
                               background.drawing=off

sketchybar --add item volume right \
           --set volume update_freq=60 \
                        width=58 \
                        icon="􀊩" \
                        icon.color=$STATUS_ICON_COLOR \
                        icon.font="SF Pro:Semibold:13.0" \
                       icon.padding_left=8 \
                       icon.padding_right=4 \
                        label.color=$TEXT_COLOR \
                        label.font="JetBrainsMono Nerd Font:Medium:12.0" \
                        label.padding_right=8 \
                        background.drawing=off \
                        popup.drawing=off \
                        popup.align=right \
                        popup.height=34 \
                        popup.y_offset=-6 \
                        popup.background.color=$BUBBLE_COLOR \
                        popup.background.border_color=$BUBBLE_BORDER \
                        popup.background.border_width=1 \
                        popup.background.corner_radius=12 \
                        script="$PLUGIN_DIR/volume.sh" \
             --subscribe volume volume_change mouse.clicked

sketchybar --add slider volume.slider popup.volume 120 \
           --set volume.slider slider.percentage=$(osascript -e 'output volume of (get volume settings)') \
                                slider.highlight_color=$STATUS_ICON_COLOR \
                                slider.background.color=0xff3e3c38 \
                                slider.background.height=4 \
                                slider.background.corner_radius=2 \
                                slider.knob="●" \
                                slider.knob.color=$TEXT_COLOR \
                                slider.knob.font="SF Pro:Semibold:12.0" \
                                icon.drawing=off \
                                label.drawing=off \
                                background.drawing=off \
                                padding_left=12 \
                                padding_right=12 \
                                y_offset=0 \
                                script="$PLUGIN_DIR/volume_slider.sh" \
            --subscribe volume.slider volume_change mouse.clicked mouse.exited

sketchybar --add item right_sep.3 right \
           --set right_sep.3 width=4 \
                               icon.drawing=off \
                               label.drawing=off \
                               background.drawing=off

sketchybar --add item memory right \
             --set memory update_freq=5 \
                         width=56 \
                         icon="􀫦" \
                         icon.color=$STATUS_ICON_COLOR \
                         icon.font="SF Pro:Semibold:13.0" \
                        icon.padding_left=8 \
                        icon.padding_right=4 \
                         label.color=$TEXT_COLOR \
                         label.font="JetBrainsMono Nerd Font:Medium:12.0" \
                         label.padding_right=8 \
                         background.drawing=off \
                         click_script="open -a 'Activity Monitor'" \
                         script="$PLUGIN_DIR/memory.sh"

sketchybar --add item right_sep.4 right \
           --set right_sep.4 width=4 \
                               icon.drawing=off \
                               label.drawing=off \
                               background.drawing=off

sketchybar --add item cpu right \
           --set cpu update_freq=2 \
                      width=56 \
                      icon="􀫥" \
                      icon.color=$STATUS_ICON_COLOR \
                      icon.font="SF Pro:Semibold:13.0" \
                     icon.padding_left=8 \
                     icon.padding_right=4 \
                      label.color=$TEXT_COLOR \
                      label.font="JetBrainsMono Nerd Font:Medium:12.0" \
                      label.padding_right=8 \
                      background.drawing=off \
                      click_script="open -a 'Activity Monitor'" \
                      script="$PLUGIN_DIR/cpu.sh"

sketchybar --add bracket right_group cpu right_sep.4 memory right_sep.3 volume right_sep.2 battery right_sep.1 settings \
           --set right_group background.drawing=on \
                                  y_offset=4 \
                                  background.color=$STATUS_BACKGROUND \
                                  background.border_color=$STATUS_BORDER \
                                  background.border_width=1 \
                                  background.height=30 \
                                  background.corner_radius=12

sketchybar --update
